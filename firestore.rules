rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isSupremeAdmin() {
      return isSignedIn() && request.auth.token.email == 'nabidahamed2003@gmail.com';
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isMemberOf(messId) {
      return isSupremeAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && messId in getUserData().messIds);
    }

    function isManagerOf(messId) {
      return isSupremeAdmin() || (
        isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        messId in getUserData().memberships && 
        getUserData().memberships[messId].role == 'Manager'
      );
    }

    function isMessAuthorityOf(messId) {
      return isSupremeAdmin() || (
        isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        messId in getUserData().memberships && 
        (getUserData().memberships[messId].role == 'Manager' || getUserData().memberships[messId].role == 'MealManager')
      );
    }

    // Users Collection
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (request.auth.uid == userId || isSupremeAdmin() || isManagerOf(resource.data.messId));
      allow delete: if isSupremeAdmin();
    }

    // Generic rule for all other collections - Granting Supreme Admin "God Mode"
    match /{path=**} {
      allow read, write: if isSupremeAdmin();
    }

    // Messes Collection
    match /messes/{messId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (
        isSupremeAdmin() ||
        (request.auth.uid in resource.data.get('managerIds', [])) || 
        (resource.data.get('managerId', '') == request.auth.uid) || 
        isManagerOf(messId)
      );
    }

    // Meals Collection
    match /meals/{mealId} {
      allow read: if isSignedIn() && isMemberOf(resource.data.messId);
      allow create: if isSignedIn() && isMemberOf(request.resource.data.messId);
      allow update, delete: if isSignedIn() && (isMemberOf(resource.data.messId) && (request.auth.uid == resource.data.memberId || isMessAuthorityOf(resource.data.messId)));
    }

    // Deposits Collection
    match /deposits/{depositId} {
      allow read: if isSignedIn() && isMemberOf(resource.data.messId);
      allow create: if isSignedIn() && isMemberOf(request.resource.data.messId);
      allow update, delete: if isSignedIn() && isManagerOf(resource.data.messId);
    }

    // Bazar Costs Collection
    match /bazarCosts/{costId} {
      allow read: if isSignedIn() && isMemberOf(resource.data.messId);
      allow create: if isSignedIn() && isMemberOf(request.resource.data.messId);
      allow update, delete: if isSignedIn() && isMessAuthorityOf(resource.data.messId);
    }

    // Rent Payments Collection
    match /rentPayments/{rentId} {
      allow read: if isSignedIn() && isMemberOf(resource.data.messId);
      allow create, update, delete: if isSignedIn() && isManagerOf(request.resource.data.messId);
    }

    // Essential Costs Collection
    match /essentialCosts/{costId} {
      allow read: if isSignedIn() && isMemberOf(resource.data.messId);
      allow create, update, delete: if isSignedIn() && isManagerOf(request.resource.data.messId);
    }

    // Settings Collection
    match /settings/{settingId} {
      allow read: if isSignedIn() && isMemberOf(settingId);
      allow create, update, delete: if isSignedIn() && isManagerOf(settingId);
    }

    // Notices Collection
    match /notices/{noticeId} {
      allow read: if isSignedIn() && isMemberOf(resource.data.messId);
      allow create, update, delete: if isSignedIn() && isMessAuthorityOf(request.resource.data.messId);
    }

    // Notifications Collection
    match /notifications/{notificationId} {
      allow read: if isSignedIn() && isMemberOf(resource.data.messId);
      allow write: if isSignedIn();
    }

    // ChatMessages Collection
    match /chatMessages/{messageId} {
      allow read: if isSignedIn() && isMemberOf(resource.data.messId);
      allow create: if isSignedIn() && isMemberOf(request.resource.data.messId) && request.resource.data.senderId == request.auth.uid;
      allow update, delete: if isSignedIn() && (isSupremeAdmin() || (resource.data.senderId == request.auth.uid && isMemberOf(resource.data.messId)));
    }

    // Presence Collection
    match /presence/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    // Polls Collection
    match /polls/{pollId} {
      allow read: if isSignedIn() && isMemberOf(resource.data.messId);
      allow create, delete: if isSignedIn() && isMessAuthorityOf(request.resource.data.messId);
      allow update: if isSignedIn() && isMemberOf(resource.data.messId);
    }
  }
}
